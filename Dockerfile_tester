FROM ubuntu:22.04

ARG SSH_USER=devops
ARG SSH_PASSWORD=devops80

ENV DEBIAN_FRONTEND=noninteractive
ENV TESTER_DIR=/tester

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3=3.10.6-* \
    python3-pip=22.0.2+dfsg-* \
    openssh-server=1:8.9p1-* \
    ca-certificates=* \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /var/run/sshd \
    && useradd -m -s /bin/bash "${SSH_USER}" \
    && echo "${SSH_USER}:${SSH_PASSWORD}" | chpasswd \
    && sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config \
    && sed -i 's/PasswordAuthentication no/PasswordAuthentication yes/' /etc/ssh/sshd_config

WORKDIR ${TESTER_DIR}

RUN mkdir -p ${TESTER_DIR}/tests ${TESTER_DIR}/logs

RUN pip3 install --no-cache-dir \
    requests==2.32.3 \
    css-html-prettify==2.5.5 \
    pylint==3.0.3

CMD service ssh start && cd /tester && exec python3 -m http.server 3000